<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.QuizQuestionMapper">

    <resultMap id="QuizQuestionResult" type="com.ruoyi.system.domain.QuizQuestion">
        <id property="id" column="id" />
        <result property="title" column="title" />
        <result property="content" column="content" />
        <result property="optionsJson" column="options" />
        <result property="correctAnswer" column="correctAnswer" />
        <result property="difficulty" column="difficulty" />
        <result property="category" column="category" />
        <result property="points" column="points" />
        <result property="createTime" column="createdAt" />
    </resultMap>

    <sql id="selectQuestionColumns">
        select id, title, content, options, correctAnswer, difficulty, category, points, createdAt
        from questions
    </sql>

    <select id="selectQuestionList" parameterType="com.ruoyi.system.domain.QuizQuestion" resultMap="QuizQuestionResult">
        <include refid="selectQuestionColumns" />
        <where>
            <if test="title != null and title != ''">
                and title like concat('%', #{title}, '%')
            </if>
            <if test="content != null and content != ''">
                and content like concat('%', #{content}, '%')
            </if>
            <if test="difficulty != null and difficulty != ''">
                and difficulty = #{difficulty}
            </if>
            <if test="category != null and category != ''">
                and category like concat('%', #{category}, '%')
            </if>
            <if test="params.beginTime != null and params.beginTime != ''">
                and createdAt &gt;= #{params.beginTime}
            </if>
            <if test="params.endTime != null and params.endTime != ''">
                and createdAt &lt;= #{params.endTime}
            </if>
        </where>
        order by createdAt desc, id desc
    </select>

    <select id="selectQuestionById" parameterType="Long" resultMap="QuizQuestionResult">
        <include refid="selectQuestionColumns" />
        where id = #{id}
    </select>

    <select id="selectQuestionsByIds" resultMap="QuizQuestionResult">
        <include refid="selectQuestionColumns" />
        where id in
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>

    <select id="selectQuestionOptionList" resultMap="QuizQuestionResult">
        select id, title, category, difficulty, points, createdAt
        from questions
        order by createdAt desc, id desc
    </select>

    <insert id="insertQuestion" parameterType="com.ruoyi.system.domain.QuizQuestion" useGeneratedKeys="true" keyProperty="id">
        insert into questions (
            title,
            content,
            options,
            correctAnswer,
            difficulty,
            category,
            points,
            createdAt
        ) values (
            #{title},
            #{content},
            #{optionsJson},
            #{correctAnswer},
            #{difficulty},
            #{category},
            #{points},
            sysdate()
        )
    </insert>

    <update id="updateQuestion" parameterType="com.ruoyi.system.domain.QuizQuestion">
        update questions
        <set>
            <if test="title != null">title = #{title},</if>
            <if test="content != null">content = #{content},</if>
            <if test="optionsJson != null">options = #{optionsJson},</if>
            <if test="correctAnswer != null">correctAnswer = #{correctAnswer},</if>
            <if test="difficulty != null and difficulty != ''">difficulty = #{difficulty},</if>
            <if test="category != null and category != ''">category = #{category},</if>
            <if test="points != null">points = #{points},</if>
        </set>
        where id = #{id}
    </update>

    <delete id="deleteQuestionByIds" parameterType="Long">
        delete from questions
        where id in
        <foreach collection="array" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>
