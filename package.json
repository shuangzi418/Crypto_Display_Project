{
  "name": "crypto-quiz-system",
  "private": true,
  "scripts": {
    "postinstall": "npm install --prefix backend && npm install --prefix frontend",
    "dev": "concurrently \"npm run dev --prefix backend\" \"npm start --prefix frontend\"",
    "stop": "kill-port 3001 5000",
    "install:all": "npm install",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm start --prefix frontend",
    "build": "npm run build --prefix frontend",
    "test": "npm test --prefix backend",
    "admin:init": "npm run admin:init --prefix backend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "kill-port": "^2.0.1"
  }
}
